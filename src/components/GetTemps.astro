---
export const prerender = false; // On-demand rendering
Astro.cache.set({
  maxAge: 3600, // Cache for 1 hour
  swr: 600,     // Stale-while-revalidate for 10 minutes
});
import { db } from '../lib/db';

const response = await fetch('https://garage.robmcd.name/');
const temps = await response.json();

const qry = 'INSERT INTO garage_temps (tempc, tempf, humidity, timestamp) VALUES($1, $2, $3, $4)';
const values = [temps.temp["avg"].c, temps.temp["avg"].f, temps.temp["avg"].h, new Date()];
const res = await db.query(qry, values);
---

<div class="temps-wrap">
  <div class="container">
    <h1>Garage Temperatures</h1>
    <div class="grid grid-cols-4 gap-4">
      <div><h3>Temp Probe 0:</h3>
      <p></p>{temps.temp["0"].c}°C, {temps.temp["0"].f}°F, {temps.temp["0"].h}%</p></div>
      <div><h3>Temp Probe 1:</h3>
      <p></p>{temps.temp["1"].c}°C, {temps.temp["1"].f}°F, {temps.temp["1"].h}%</p></div>
      <div><h3>Average:</h3>
      <p></p>{temps.temp["avg"].c}°C, {temps.temp["avg"].f}°F, {temps.temp["avg"].h}%</p></div>
    </div>
  </div>
</div>
<style>
    .temps-wrap {
        background: rgba(255, 255, 255, 0.2); /* Semi-transparent color */
        backdrop-filter: blur(10px);          /* Blurs content behind */
        -webkit-backdrop-filter: blur(10px);
        margin: 20px;
        padding: 20px;
        border-radius: 8px;
        border: 1px solid #000;
    }  
</style>